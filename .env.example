# Variáveis de ambiente — copiar para .env e preencher os valores
# O arquivo .env NUNCA vai para o commit (ver .gitignore)

# Banco de dados local (docker compose)
DATABASE_URL=postgresql://ligcentro:ligcentro@localhost:5432/ligcentro

# Porta da aplicação no host (docker compose) — padrão 3000
# Se 3000 já estiver em uso, define outra: APP_PORT=3001 docker compose up
APP_PORT=3000

# Supabase (produção — preencher após criar o projeto no supabase.com)
# NEXT_PUBLIC_SUPABASE_URL=https://<projeto>.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
