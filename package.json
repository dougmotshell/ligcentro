{
  "name": "ligcentro",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run --passWithNoTests",
    "test:e2e": "playwright test --pass-with-no-tests",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:seed": "psql $DATABASE_URL -f db/seeds/001_demo_profile.sql",
    "db:migrate": "psql $DATABASE_URL -f db/migrations/0001_profiles_blocks.sql"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "next": "15.5.20",
    "next-intl": "^3.26.5",
    "postgres": "^3.4.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.82.0",
    "react-icons": "^5.7.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.6",
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.10",
    "autoprefixer": "^10.5.4",
    "eslint": "^9.39.5",
    "eslint-config-next": "15.5.20",
    "jsdom": "^26.0.0",
    "postcss": "^8.5.20",
    "prettier": "^3.9.5",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^8.1.5",
    "vitest": "^4.1.10"
  }
}
